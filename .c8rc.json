{
  "all": true,
  "include": [
    "out/**/*.js"
  ],
  "exclude": [
    "out/test/**/*",
    "out/unit/**/*"
  ],
  "reporter": [
    "text",
    "lcov",
    "html"
  ],
  "reports-dir": "./coverage",
  "clean": true,
  "check-coverage": true,
  "lines": 80,
  "statements": 80,
  "branches": 88,
  "functions": 95
}
