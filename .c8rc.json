{
  "all": true,
  "include": [
    "out/**/*.js"
  ],
  "exclude": [
    "out/test/**/*",
    "out/unit/**/*",
    "out/extension.js",
    "out/configuration.js",
    "out/providers/**/*"
  ],
  "reporter": [
    "text",
    "lcov",
    "html"
  ],
  "reports-dir": "./coverage",
  "clean": true,
  "check-coverage": true,
  "lines": 95,
  "statements": 95,
  "branches": 88,
  "functions": 97
}
